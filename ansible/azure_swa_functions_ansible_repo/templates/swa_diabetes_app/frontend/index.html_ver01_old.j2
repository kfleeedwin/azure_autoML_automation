<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ app_title }}</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #07111f;
      --panel: #0e1b2f;
      --line: #1f3558;
      --text: #e8f0ff;
      --muted: #9db4db;
      --accent: #33d1ff;
      --good: #113623;
      --bad: #4a1717;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 32px 18px;
      background: linear-gradient(180deg, #050b14 0%, var(--bg) 100%);
      color: var(--text);
      font-family: Inter, Segoe UI, Arial, sans-serif;
    }
    .wrap {
      max-width: 920px;
      margin: 0 auto;
    }
    .hero {
      margin-bottom: 20px;
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(14, 27, 47, 0.9);
      box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
    }
    h1 {
      margin: 0 0 8px;
      font-size: 2rem;
    }
    p {
      margin: 0;
      color: var(--muted);
      line-height: 1.5;
    }
    .panel {
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(14, 27, 47, 0.92);
      box-shadow: 0 18px 60px rgba(0, 0, 0, 0.28);
    }
    form {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }
    label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: #dbe7ff;
    }
    input {
      width: 100%;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #07111f;
      color: var(--text);
      outline: none;
    }
    input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(51, 209, 255, 0.18);
    }
    .full { grid-column: 1 / -1; }
    button {
      padding: 14px 18px;
      border: 0;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      background: linear-gradient(90deg, #1ea7ff 0%, #33d1ff 100%);
      color: #04101d;
    }
    .result {
      display: none;
      margin-top: 18px;
      padding: 16px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: #0a1527;
    }
    .result.ok { background: var(--good); }
    .result.bad { background: var(--bad); }
    pre {
      margin: 12px 0 0;
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 0.9rem;
    }
    .meta {
      margin-top: 18px;
      font-size: 0.88rem;
      color: var(--muted);
    }
    @media (max-width: 720px) {
      form { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="hero">
      <h1>{{ app_title }}</h1>
      <p>{{ app_description }}</p>
      <div class="meta">This page posts to <code>/api/{{ function_route_name }}</code> on the linked Azure Function backend.</div>
    </div>

    <div class="panel">
      <form id="predictForm">
        <div>
          <label for="PatientID">PatientID</label>
          <input id="PatientID" name="PatientID" type="number" required />
        </div>
        <div>
          <label for="Pregnancies">Pregnancies</label>
          <input id="Pregnancies" name="Pregnancies" type="number" required />
        </div>
        <div>
          <label for="PlasmaGlucose">PlasmaGlucose</label>
          <input id="PlasmaGlucose" name="PlasmaGlucose" type="number" step="any" required />
        </div>
        <div>
          <label for="DiastolicBloodPressure">DiastolicBloodPressure</label>
          <input id="DiastolicBloodPressure" name="DiastolicBloodPressure" type="number" step="any" required />
        </div>
        <div>
          <label for="TricepsThickness">TricepsThickness</label>
          <input id="TricepsThickness" name="TricepsThickness" type="number" step="any" required />
        </div>
        <div>
          <label for="SerumInsulin">SerumInsulin</label>
          <input id="SerumInsulin" name="SerumInsulin" type="number" step="any" required />
        </div>
        <div>
          <label for="BMI">BMI</label>
          <input id="BMI" name="BMI" type="number" step="any" required />
        </div>
        <div>
          <label for="DiabetesPedigree">DiabetesPedigree</label>
          <input id="DiabetesPedigree" name="DiabetesPedigree" type="number" step="any" required />
        </div>
        <div>
          <label for="Age">Age</label>
          <input id="Age" name="Age" type="number" required />
        </div>
        <div class="full">
          <button type="submit">Run prediction</button>
        </div>
      </form>

      <div id="result" class="result"></div>
    </div>
  </div>

  <script>
    const form = document.getElementById('predictForm');
    const resultEl = document.getElementById('result');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      resultEl.style.display = 'block';
      resultEl.className = 'result';
      resultEl.textContent = 'Submitting request...';

      const payload = {
        PatientID: Number(form.PatientID.value),
        Pregnancies: Number(form.Pregnancies.value),
        PlasmaGlucose: Number(form.PlasmaGlucose.value),
        DiastolicBloodPressure: Number(form.DiastolicBloodPressure.value),
        TricepsThickness: Number(form.TricepsThickness.value),
        SerumInsulin: Number(form.SerumInsulin.value),
        BMI: Number(form.BMI.value),
        DiabetesPedigree: Number(form.DiabetesPedigree.value),
        Age: Number(form.Age.value)
      };

      try {
        const response = await fetch('/api/{{ function_route_name }}', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'Prediction request failed');
        }

        resultEl.className = 'result ' + (data.prediction ? 'ok' : 'bad');
        resultEl.innerHTML = `
          <strong>Prediction:</strong> ${data.prediction ? 'TRUE' : 'FALSE'}<br>
          <strong>Label:</strong> ${data.label}<br>
          <strong>AML endpoint:</strong> ${data.aml_endpoint_name || 'n/a'}<br>
          <strong>Model:</strong> ${data.aml_model_name || 'n/a'} ${data.aml_model_version ? '(v' + data.aml_model_version + ')' : ''}
          <pre>${JSON.stringify(data.raw, null, 2)}</pre>
        `;
      } catch (error) {
        resultEl.className = 'result bad';
        resultEl.innerHTML = `<strong>Error:</strong> ${error.message}`;
      }
    });
  </script>
</body>
</html>
